# Server Configuration
PORT=3000

# CORS — comma-separated list of allowed frontend origins
# In production, replace with your actual deployed frontend URL(s)
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Email Configuration (for password reset)
# Use a Gmail account with an App Password (not your regular password)
# To generate an App Password: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend API URL (for Vite)
# Leave BLANK in development — the Vite dev server proxies /api/* to localhost:3000 automatically.
# In production, set this to your deployed backend URL (e.g. https://your-api.onrender.com).
VITE_API_URL=

# Firebase Client SDK (Vite — exposed to browser, safe to publish)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
